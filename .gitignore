# Dependências
frontend/node_modules/

# Build do Next.js
frontend/.next/
frontend/out/

# Variáveis de ambiente (nunca commitar)
frontend/.env.local
frontend/.env*.local
.env.local
.env*.local

# Logs
*.log
npm-debug.log*

# Sistema operacional
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Python cache (dentro de .claude/)
**/__pycache__/
**/*.pyc

# TypeScript build cache
frontend/tsconfig.tsbuildinfo

# Prisma (gerado automaticamente)
frontend/node_modules/.prisma/

# Pastas geradas localmente que não sobem para Source Control
.agent/
.claude/

# Playwright — artefatos de teste gerados automaticamente
frontend/test-results/
frontend/playwright-report/
frontend/.playwright/

# Worktrees
.worktrees/
